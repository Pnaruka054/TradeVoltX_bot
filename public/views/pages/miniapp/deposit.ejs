<div class="payment-flat-view animate-in">
    <!-- Header -->
    <div class="flat-header text-center py-3">
        <h3 class="fw-bold mb-0">Complete Payment</h3>
        <div class="network-badge-row d-flex justify-content-center align-items-center mt-2">
            <div class="network-badge">
                <img src="https://cryptologos.cc/logos/tether-usdt-logo.svg?v=025" width="16" alt="USDT">
                <span>USDT (BEP20)</span>
            </div>
        </div>
    </div>

    <div class="payment-content px-3">
        <!-- Amount Section -->
        <div class="flat-amount-section text-center mb-3">
            <span class="label-tiny">PAYABLE AMOUNT</span>
            <div class="d-flex justify-content-center align-items-center mt-0">
                <span class="amount-value" id="payableAmount"><%= amount %></span>
                <span class="currency-label ms-2">USDT</span>
                <button class="flat-copy-btn ms-2" onclick="copyToClipboard('payableAmount')" title="Copy Amount">
                    <i class="bi bi-copy"></i>
                </button>
            </div>
        </div>

        <!-- QR Section -->
        <div class="flat-qr-section text-center mb-3">
            <div class="qr-placeholder">
                <% if (qrCode) { %>
                    <img src="<%= qrCode %>" class="img-fluid" style="max-width: 140px;" alt="Payment QR">
                <% } else { %>
                    <div class="qr-missing">QR Code Not Set</div>
                <% } %>
            </div>
        </div>

        <!-- Address Section -->
        <div class="flat-data-row mb-3">
            <span class="label-tiny">DEPOSIT ADDRESS</span>
            <div class="data-display mt-1">
                <code id="usdtAddress" class="text-break"><%= usdtAddress %></code>
                <button class="btn-copy-link" onclick="copyToClipboard('usdtAddress')">COPY</button>
            </div>
            <div class="network-note mt-2">
                <i class="bi bi-info-circle-fill"></i>
                <span>Send only USDT to this address via <b>BNB Smart Chain (BEP20)</b>.</span>
            </div>
        </div>

        <!-- Input Section -->
        <div class="flat-input-group mb-3">
            <label class="label-tiny fw-bold">TRANSACTION HASH / TXID</label>
            <input type="text" id="txnId" class="minimal-input mt-1" 
                   placeholder="Paste hash here..."
                   oninput="this.value = this.value.toUpperCase()">
        </div>

        <button id="submitBtn" onclick="submitDeposit()" class="btn-flat-primary w-100 py-3 mb-4 shadow-sm">
            VERIFY & SUBMIT
        </button>
    </div>
</div>

<!-- Simple Success Overly -->
<div id="successModal" class="flat-overlay" style="display: none;">
    <div class="flat-modal-body animate-in">
        <i class="bi bi-check-circle-fill text-success mb-2" style="font-size: 3rem;"></i>
        <h4 class="fw-bold">Submitted!</h4>
        <p class="text-muted-alt smallest">Verifying your deposit. Plan active soon.</p>
        <button onclick="closePaymentPage()" class="btn-flat-primary w-100 mt-2 py-2">OKAY</button>
    </div>
</div>

<style>
    :root {
        --bg-color: #0d0d0f;
        --text-main: #ffffff;
        --text-muted: #8e8e93;
        --accent-blue: #007aff;
        --soft-bg: #1c1c1e;
        --warning-gold: #ffd60a;
        --usdt-green: #26a17b;
    }

    body { 
        background-color: var(--bg-color); 
        color: var(--text-main);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        overflow-x: hidden;
    }

    .payment-flat-view {
        max-width: 420px;
        margin: 0 auto;
    }

    .network-badge {
        background: rgba(38, 161, 123, 0.15);
        color: #58d68d;
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 0.65rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 6px;
        border: 1px solid rgba(38, 161, 123, 0.3);
    }

    .label-tiny {
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        color: var(--text-muted);
    }

    .amount-value {
        font-size: 2.5rem;
        font-weight: 800;
        letter-spacing: -0.02em;
    }

    .currency-label {
        font-size: 1rem;
        font-weight: 600;
        color: var(--usdt-green);
    }

    .flat-copy-btn {
        background: var(--soft-bg);
        border: none;
        color: var(--accent-blue);
        padding: 6px;
        border-radius: 8px;
        display: flex;
        cursor: pointer;
    }

    .qr-placeholder {
        background: white;
        padding: 10px;
        border-radius: 16px;
        display: inline-block;
        box-shadow: 0 0 15px rgba(255,255,255,0.05);
    }
    .qr-missing {
        padding: 20px;
        color: #000;
        font-size: 0.7rem;
    }

    .data-display {
        background: var(--soft-bg);
        padding: 14px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }
    .data-display code {
        color: #fff;
        font-size: 0.8rem;
    }

    .btn-copy-link {
        background: none;
        border: none;
        color: var(--accent-blue);
        font-weight: 800;
        font-size: 0.7rem;
    }

    .network-note {
        font-size: 0.65rem;
        color: var(--text-muted);
        display: flex;
        gap: 6px;
    }
    .network-note b { color: var(--warning-gold); }

    .minimal-input {
        width: 100%;
        background: var(--soft-bg);
        border: 2px solid transparent;
        border-radius: 12px;
        padding: 14px;
        color: #fff;
        font-size: 0.95rem;
    }
    .minimal-input:focus {
        outline: none;
        border-color: var(--accent-blue);
    }

    .btn-flat-primary {
        background: var(--accent-blue);
        color: #fff;
        border: none;
        border-radius: 14px;
        font-weight: 700;
        font-size: 1rem;
    }

    /* Modal */
    .flat-overlay {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.9); display: flex; align-items: center; justify-content: center;
        z-index: 9999; padding: 20px;
    }
    .flat-modal-body {
        background: var(--soft-bg); padding: 20px; border-radius: 24px;
        text-align: center; width: 100%; max-width: 300px;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(5px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-in { animation: fadeIn 0.3s ease-out; }
</style>

<script>
const amount = '<%= amount %>';
const userId = '<%= user.userID %>';

function closePaymentPage() {
    if (window.Telegram && Telegram.WebApp) Telegram.WebApp.close();
    window.close();
    document.body.innerHTML = '<div style="height:100vh; display:flex; align-items:center; justify-content:center; text-align:center;"><h2 style="color:#007aff;">Done!</h2></div>';
}

function copyToClipboard(elementId) {
    const text = document.getElementById(elementId).innerText;
    const textArea = document.createElement("textarea");
    textArea.value = text;
    document.body.appendChild(textArea);
    textArea.select();
    try {
        document.execCommand('copy');
        if (window.Telegram && Telegram.WebApp && typeof Telegram.WebApp.showPopup === 'function') {
            Telegram.WebApp.showPopup({
                title: 'Copied!',
                message: 'Saved to clipboard',
                buttons: [{ type: 'ok' }]
            });
        } else {
            const btn = event?.currentTarget;
            if (btn) {
                const icon = btn.querySelector('i') || btn;
                const oldClass = icon.className;
                icon.className = 'bi bi-check2 text-success';
                setTimeout(() => { icon.className = oldClass; }, 1500);
            }
        }
    } catch (err) { }
    document.body.removeChild(textArea);
}

async function submitDeposit() {
    const txnId = document.getElementById('txnId').value.trim();
    if (!txnId) return;

    const btn = document.getElementById('submitBtn');
    btn.disabled = true;
    btn.innerText = 'PROCESSING...';

    try {
        const response = await fetch('/open-app/api/deposit/submit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId, amount, method: 'USDT', txnId })
        });
        const result = await response.json();
        if (result.success) {
            document.getElementById('successModal').style.display = 'flex';
        } else {
            alert(result.error);
            btn.disabled = false;
            btn.innerText = 'VERIFY & SUBMIT';
        }
    } catch (err) {
        btn.disabled = false;
        btn.innerText = 'VERIFY & SUBMIT';
    }
}
</script>
