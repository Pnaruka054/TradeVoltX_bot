<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Team Income Logs</h2>
    <div class="text-muted small">Showing <%= logs.length %> of <%= totalRecords %> Logs</div>
</div>

<div class="stat-card mb-4">
    <form action="/admin/team-income" method="GET" class="row g-3 p-3">
        <div class="col-md-5">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                <input type="text" name="search" class="form-control border-start-0" placeholder="Search by Earner or Source ID..." value="<%= search %>">
            </div>
        </div>
        <div class="col-md-3">
            <select name="limit" class="form-select">
                <option value="10" <%= limit == 10 ? 'selected' : '' %>>10 per page</option>
                <option value="30" <%= limit == 30 ? 'selected' : '' %>>30 per page</option>
                <option value="50" <%= limit == 50 ? 'selected' : '' %>>50 per page</option>
                <option value="100" <%= limit == 100 ? 'selected' : '' %>>100 per page</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Apply</button>
        </div>
        <div class="col-md-2">
            <a href="/admin/team-income" class="btn btn-outline-secondary w-100">Clear</a>
        </div>
    </form>
</div>

<div class="stat-card">
    <div class="table-responsive">
        <table class="table align-middle no-hover">
            <thead class="table-light">
                <tr>
                    <th>Date</th>
                    <th>Earner ID</th>
                    <th>Source ID</th>
                    <th>Level</th>
                    <th>Type</th>
                    <th>Amount</th>
                </tr>
            </thead>
            <tbody>
                <% if (logs.length === 0) { %>
                    <tr><td colspan="6" class="text-center py-4 text-muted">No team income logs found.</td></tr>
                <% } %>
                <% logs.forEach(log => { %>
                    <tr>
                        <td class="small"><%= log.createdAt.toLocaleString('en-IN') %></td>
                        <td><a href="/admin/users/<%= log.earnerId %>" class="fw-bold"><%= log.earnerId %></a></td>
                        <td><a href="/admin/users/<%= log.sourceId %>" class="fw-bold"><%= log.sourceId %></a></td>
                        <td><span class="badge bg-info text-dark">Level <%= log.level %></span></td>
                        <td><span class="text-uppercase smallest"><%= log.incomeType.replace('_', ' ') %></span></td>
                        <td class="text-success fw-bold"><%= log.amount.toFixed(2) %> USDT</td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <% if (totalPages > 1) { %>
        <div class="d-flex justify-content-center p-3 border-top">
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
                        <a class="page-link" href="/admin/team-income?page=<%= page - 1 %>&limit=<%= limit %>&search=<%= search %>">Previous</a>
                    </li>
                    <% for(let i=1; i<=totalPages; i++) { %>
                        <li class="page-item <%= page === i ? 'active' : '' %>">
                            <a class="page-link" href="/admin/team-income?page=<%= i %>&limit=<%= limit %>&search=<%= search %>"><%= i %></a>
                        </li>
                    <% } %>
                    <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
                        <a class="page-link" href="/admin/team-income?page=<%= page + 1 %>&limit=<%= limit %>&search=<%= search %>">Next</a>
                    </li>
                </ul>
            </nav>
        </div>
    <% } %>
</div>

<style>
    .no-hover tr:hover {
        background-color: transparent !important;
        box-shadow: none !important;
    }
    .smallest { font-size: 0.7rem; }
</style>
