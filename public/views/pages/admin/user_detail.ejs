<div class="mb-4">
    <a href="/admin/users" class="btn btn-sm btn-outline-secondary mb-3"><i class="bi bi-arrow-left"></i> Back to Users</a>
    <div class="d-flex justify-content-between align-items-start">
        <h2>User Detail: <%= user.firstName %> (<%= user.userID %>)</h2>
        <div>
            <% if (user.isBlocked) { %>
                <form action="/admin/users/<%= user.userID %>/unblock" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-success">Unblock User</button>
                </form>
            <% } else { %>
                <form action="/admin/users/<%= user.userID %>/block" method="POST" class="d-inline">
                    <button type="submit" class="btn btn-warning">Block User</button>
                </form>
            <% } %>
            <form action="/admin/users/<%= user.userID %>/delete" method="POST" class="d-inline" onsubmit="return confirm('❗ ARE YOU SURE? ❗\n\nThis will PERMANENTLY DELETE the user and ALL their related data (Transactions, Withdrawals, Team Income, ROI Claims).\n\nThis action CANNOT be undone.');">
                <button type="submit" class="btn btn-danger ms-1">Delete User</button>
            </form>
        </div>

<% if (typeof query !== 'undefined' && query.error) { %>
    <div class="alert alert-danger alert-dismissible fade show py-2 small mb-3" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> <strong>Error:</strong> <%= query.error %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" style="padding: 0.7rem;"></button>
    </div>
<% } %>
    </div>
</div>

<ul class="nav nav-tabs mb-4" id="userTabs" role="tablist">
    <li class="nav-item">
        <a class="nav-link active" id="overview-tab" data-bs-toggle="tab" href="#overview" role="tab">Overview</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" id="transactions-tab" data-bs-toggle="tab" href="#transactions" role="tab">Transactions</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" id="team-tab" data-bs-toggle="tab" href="#team" role="tab">Team Report</a>
    </li>
</ul>

<form action="/admin/users/<%= user.userID %>" method="GET" class="row g-3 mb-4 align-items-end p-3 bg-white rounded shadow-sm">
    <div class="col-md-3">
        <label class="form-label text-muted small mb-1">Month</label>
        <select name="month" class="form-select form-select-sm">
            <option value="">All Time</option>
            <% const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"]; %>
            <% months.forEach((m, i) => { %>
                <option value="<%= i + 1 %>" <%= (i + 1) == currentMonth ? 'selected' : '' %>><%= m %></option>
            <% }) %>
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label text-muted small mb-1">Year</label>
        <select name="year" class="form-select form-select-sm">
            <option value="">All Time</option>
            <% const year = new Date().getFullYear(); %>
            <option value="<%= year %>" <%= year == currentYear ? 'selected' : '' %>><%= year %></option>
            <option value="<%= year - 1 %>" <%= (year - 1) == currentYear ? 'selected' : '' %>><%= year - 1 %></option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-sm btn-primary w-100">Apply Filter</button>
    </div>
</form>

<div class="tab-content" id="userTabsContent">
    <div class="tab-pane fade show active" id="overview" role="tabpanel">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="stat-card mb-4">
                    <h5>Profile Info</h5>
                    <hr>
                    <p><strong>Telegram ID:</strong> <%= user.telegramId %></p>
                    <p><strong>Username:</strong> @<%= user.username || 'N/A' %></p>
                    <p><strong>Joined:</strong> <%= user.createdAt.toLocaleString('en-IN') %></p>
                    <p><strong>Referred By:</strong> <%= user.referredBy || 'None' %></p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card mb-4">
                    <h5>Wallet & Plan</h5>
                    <hr>
                    <p><strong>Wallet Balance:</strong> <%= user.walletBalance.toFixed(2) %> USDT</p>
                    <p><strong>Total Earned:</strong> <%= user.totalEarned.toFixed(2) %> USDT</p>
                    <h6 class="mt-3">Active Plans:</h6>
                    <ul class="list-unstyled small">
                        <% if (user.activePlans && user.activePlans.length > 0) { %>
                            <% user.activePlans.forEach((plan, idx) => { %>
                                <li class="mb-2 p-2 bg-light rounded border-start border-3 <%= plan.isActive ? 'border-success' : 'border-secondary' %>">
                                    <strong>#<%= idx + 1 %>: <%= plan.planAmount %> USDT</strong><br>
                                    Progress: <%= plan.daysCompleted %>/100 Days<br>
                                    Status: <%= plan.isActive ? 'Active' : 'Expired' %>
                                </li>
                            <% }) %>
                        <% } else { %>
                            <li class="text-muted">No plans found.</li>
                        <% } %>
                    </ul>
                    <div class="d-flex gap-2 mt-3">
                        <button class="btn btn-sm btn-primary flex-grow-1" data-bs-toggle="modal" data-bs-target="#adjustBalanceModal">Adjust Balance</button>
                        <button class="btn btn-sm btn-warning flex-grow-1" data-bs-toggle="modal" data-bs-target="#activatePlanModal">Activate Plan</button>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <h5>Payment Details</h5>
                    <hr>
                    <p><strong>USDT Address:</strong> <%= user.bankDetails.usdtAddress || 'Not Set' %></p>
                    <p><strong>Network:</strong> <%= user.bankDetails.usdtNetwork %></p>
                </div>
            </div>
        </div>
    </div>

    <div class="tab-pane fade" id="transactions" role="tabpanel">
        <div class="stat-card">
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>Type</th>
                            <th>Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (transactions.length === 0) { %>
                            <tr><td colspan="4" class="text-center py-4">No transactions found.</td></tr>
                        <% } %>
                        <% transactions.forEach(tx => { %>
                            <tr>
                                <td><%= tx.createdAt.toLocaleString('en-IN') %></td>
                                <td class="text-uppercase"><%= tx.type.replace('_', ' ') %></td>
                                <td class="<%= (tx.type === 'withdrawal') ? 'text-danger' : 'text-success' %> fw-bold">
                                    <%= (tx.type === 'withdrawal') ? '-' : '+' %><%= tx.amount.toFixed(2) %> USDT
                                </td>
                                <td><span class="badge bg-<%= tx.status === 'completed' ? 'success' : (tx.status === 'pending' ? 'warning' : 'danger') %>"><%= tx.status %></span></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <% if (totalPages > 1) { %>
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                            <a class="page-link" href="?page=<%= currentPage - 1 %>&month=<%= currentMonth %>&year=<%= currentYear %>">Previous</a>
                        </li>
                        <li class="page-item active"><span class="page-link"><%= currentPage %> of <%= totalPages %></span></li>
                        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                            <a class="page-link" href="?page=<%= currentPage + 1 %>&month=<%= currentMonth %>&year=<%= currentYear %>">Next</a>
                        </li>
                    </ul>
                </nav>
            <% } %>
        </div>
    </div>

    <div class="tab-pane fade" id="team" role="tabpanel">
        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="stat-card bg-light border-start border-4 border-primary">
                    <div class="text-muted mb-1">Total Team Earnings (Filtered)</div>
                    <h3 class="mb-0 text-primary"><%= totalTeamEarnings.toFixed(2) %> USDT</h3>
                </div>
            </div>
            <div class="col-md-6">
                <div class="stat-card bg-light border-start border-4 border-success">
                    <div class="text-muted mb-1">Direct Referrals (Level 1)</div>
                    <h3 class="mb-0 text-success"><%= level1.length %></h3>
                </div>
            </div>
        </div>

        <div class="stat-card">
            <h5 class="mb-3">Level 1 Members</h5>
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>User ID</th>
                            <th>Name</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (level1.length === 0) { %>
                            <tr><td colspan="3" class="text-center text-muted py-4">No direct referrals.</td></tr>
                        <% } %>
                        <% level1.forEach(m => { %>
                            <tr>
                                <td><a href="/admin/users/<%= m.userID %>" class="fw-bold"><%= m.userID %></a></td>
                                <td><%= m.firstName %></td>
                                <td>
                                    <% const hasActive = m.activePlans && m.activePlans.some(p => p.isActive); %>
                                    <span class="badge bg-<%= hasActive ? 'success' : 'secondary' %>">
                                        <%= hasActive ? 'Active' : 'No Plan' %>
                                    </span>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="adjustBalanceModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="/admin/users/<%= user.userID %>/adjust-balance" method="POST">
                <div class="modal-header">
                    <h5 class="modal-title">Adjust Wallet Balance</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Action</label>
                        <select name="actionType" class="form-select" required>
                            <option value="add">➕ Add Balance</option>
                            <option value="subtract">➖ Subtract Balance</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Amount (USDT)</label>
                        <input type="number" step="0.01" min="0.01" name="amount" class="form-control" placeholder="0.00" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Reason</label>
                        <input type="text" name="reason" class="form-control" required placeholder="Bonus, Correction, Manual Adjustment, etc.">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="activatePlanModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="/admin/users/<%= user.userID %>/activate-plan" method="POST">
                <div class="modal-header">
                    <h5 class="modal-title">Activate Investment Plan</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small">Select a plan to activate for this user. Multiple plans can be active at the same time.</p>
                    <div class="mb-3">
                        <label class="form-label">Choose Plan</label>
                        <% 
                            const activeAmounts = (user.activePlans || []).filter(p => p.isActive).map(p => p.planAmount);
                            const plans = [
                                { amount: 30, daily: 0.60, label: '30 USDT' },
                                { amount: 50, daily: 1.00, label: '50 USDT' },
                                { amount: 100, daily: 2.00, label: '100 USDT' },
                                { amount: 200, daily: 4.00, label: '200 USDT' },
                                { amount: 500, daily: 10.00, label: '500 USDT' },
                                { amount: 1000, daily: 20.00, label: '1000 USDT' }
                            ];
                            const availablePlans = plans.filter(p => !activeAmounts.includes(p.amount));
                        %>
                        <select name="planAmount" class="form-select" required>
                            <option value="">Select Plan...</option>
                            <% if (availablePlans.length === 0) { %>
                                <option value="" disabled>All plan types are already active</option>
                            <% } else { %>
                                <% availablePlans.forEach(p => { %>
                                    <option value="<%= p.amount %>">💎 Plan <%= p.label %> (<%= p.daily %> USDT/day)</option>
                                <% }) %>
                            <% } %>
                        </select>
                    </div>
                    <div class="alert alert-info py-2 small">
                        <i class="bi bi-info-circle me-1"></i> User will be notified via Telegram once activated.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-warning">Activate Now</button>
                </div>
            </form>
        </div>
    </div>
</div>
<script>
if(window.location.search.includes('page=') || window.location.search.includes('month=')) {
    new bootstrap.Tab(document.querySelector('#transactions-tab')).show();
}
</script>
