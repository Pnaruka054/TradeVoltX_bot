<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Daily ROI Codes</h2>
    <div>
        <% if (canGenerate) { %>
            <form action="/admin/roi-codes/generate" method="POST">
                <button type="submit" class="btn btn-primary shadow-sm"><i class="bi bi-plus-circle me-1"></i> Generate New Code</button>
            </form>
        <% } else { %>
            <button class="btn btn-secondary" disabled title="Maximum 2 codes per day allowed">Generate New Code</button>
        <% } %>
    </div>
</div>

<div class="alert alert-info py-2 small mb-4 shadow-sm border-0 bg-white">
    <i class="bi bi-info-circle-fill text-primary me-2"></i> Admins can generate up to 2 codes per day. Each code is valid for <strong>30 minutes</strong> and allows users to claim <strong>50%</strong> of their daily ROI.
</div>

<div class="stat-card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4">Generated At</th>
                    <th>Redemption Code</th>
                    <th>Expires At</th>
                    <th>Status</th>
                    <th class="pe-4 text-end">Claims</th>
                </tr>
            </thead>
            <tbody>
                <% if (codes.length === 0) { %>
                    <tr><td colspan="5" class="text-center py-5 text-muted">No codes generated today.</td></tr>
                <% } %>
                <% codes.forEach(c => { %>
                    <% 
                        const now = new Date();
                        const isExpired = now > c.expiresAt;
                    %>
                    <tr>
                        <td class="ps-4 text-muted small"><%= c.createdAt.toLocaleString('en-IN', { hour:'2-digit', minute:'2-digit', second:'2-digit', day:'2-digit', month:'short' }) %></td>
                        <td>
                            <code class="roi-code-display" 
                                  onclick="copyToClipboard('<%= c.code %>')"
                                  title="Click to Copy">
                                <%= c.code %>
                            </code>
                        </td>
                        <td class="small text-muted"><%= c.expiresAt.toLocaleString('en-IN', { hour:'2-digit', minute:'2-digit', second:'2-digit' }) %></td>
                        <td>
                            <% if (isExpired) { %>
                                <span class="badge bg-danger-subtle text-danger px-3 py-2 rounded-pill">Expired</span>
                            <% } else { %>
                                <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill">Active</span>
                            <% } %>
                        </td>
                        <td class="pe-4 text-end">
                            <span class="fw-bold text-dark"><%= claimCounts[c._id] %></span> 
                            <span class="text-muted small">Claims</span>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<!-- Global Copy Toast (Fixed position, center bottom) -->
<div id="globalCopyToast" class="global-toast d-none">
    <i class="bi bi-check2-circle me-2"></i> Code Copied!
</div>

<style>
    .roi-code-display {
        font-size: 1.3rem;
        font-weight: 700;
        color: #0d6efd;
        cursor: pointer;
        padding: 5px 12px;
        background: #f1f7ff;
        border: 1px dashed #cfe2ff;
        border-radius: 6px;
        transition: all 0.2s;
        display: inline-block;
        font-family: 'Courier New', Courier, monospace;
    }
    .roi-code-display:hover {
        background: #0d6efd;
        color: white;
        border-style: solid;
        box-shadow: 0 4px 8px rgba(13, 110, 253, 0.2);
    }
    .roi-code-display:active {
        transform: scale(0.95);
    }

    /* Global Toast Style */
    .global-toast {
        position: fixed;
        bottom: 30px;
        left: 50%;
        transform: translateX(-50%);
        background: #198754;
        color: white;
        padding: 10px 24px;
        border-radius: 50px;
        font-weight: 600;
        z-index: 9999;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        animation: toastUp 2s ease-in-out forwards;
        display: flex;
        align-items: center;
    }

    @keyframes toastUp {
        0% { opacity: 0; bottom: 10px; }
        15% { opacity: 1; bottom: 30px; }
        85% { opacity: 1; bottom: 30px; }
        100% { opacity: 0; bottom: 40px; }
    }

    .bg-success-subtle { background-color: #e6f4ea; }
    .bg-danger-subtle { background-color: #fce8e6; }
</style>

<script>
let toastTimer;

function copyToClipboard(text) {
    if (toastTimer) clearTimeout(toastTimer);

    const toast = document.getElementById('globalCopyToast');

    // Modern API with fallback
    if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(text).then(() => showToast(toast));
    } else {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        document.body.appendChild(textArea);
        textArea.select();
        try {
            document.execCommand('copy');
            showToast(toast);
        } catch (err) {
            console.error('Copy failed', err);
        }
        document.body.removeChild(textArea);
    }
}

function showToast(el) {
    el.classList.remove('d-none');
    
    // Refresh animation
    el.style.animation = 'none';
    el.offsetHeight; 
    el.style.animation = null;

    toastTimer = setTimeout(() => {
        el.classList.add('d-none');
    }, 2000);
}
</script>
