<div class="card shadow-sm border-0 mb-4">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="card-title mb-0">Platform Settings</h4>
            <span class="text-muted small">Last Updated: <%= settings.updatedAt.toLocaleString('en-IN') %></span>
        </div>
        
        <form action="/admin/settings" method="POST" enctype="multipart/form-data">
            <div class="row g-4 justify-content-center">
                <!-- USDT Settings -->
                <div class="col-md-8">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-success text-white py-3">
                            <h5 class="mb-0"><i class="bi bi-coin me-2"></i>USDT (BEP20) Details</h5>
                        </div>
                        <div class="card-body p-4">
                            <div class="mb-4">
                                <label class="form-label fw-bold">USDT Wallet Address</label>
                                <input type="text" name="usdtAddress" class="form-control form-control-lg" value="<%= settings.depositDetails.usdt.address %>" placeholder="0x..." required>
                                <div class="mt-2 small text-danger fw-bold"><i class="bi bi-exclamation-triangle-fill me-1"></i>Network: BEP20 Only</div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Payment QR Code (USDT)</label>
                                <input type="file" name="usdtQr" class="form-control" accept="image/*">
                                <% if (settings.depositDetails.usdt.qrCodeUrl) { %>
                                    <div class="mt-3 p-2 bg-light rounded text-center">
                                        <img src="<%= settings.depositDetails.usdt.qrCodeUrl %>" class="img-thumbnail shadow-sm" style="max-height: 200px;" alt="USDT QR">
                                        <p class="smallest text-muted mt-2 mb-0">Current Active QR Code</p>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-8 mt-4 text-center">
                    <button type="submit" class="btn btn-primary btn-lg px-5 shadow-sm rounded-pill">Save Platform Settings</button>
                </div>
            </div>
        </form>
    </div>
</div>
